# Credentials and secrets — NEVER commit
db-creds.txt
*.env
.env*
*credentials*
*.pem
*.key
secrets/
.aws/
.anthropic/
.google/

# Result store. The Streamlit Cloud dashboard's Per-Row Drill page needs
# the predictions parquet, so we now commit it. Raw inference shards stay
# excluded (they're large, reproducible from predictions.parquet).
results/shards/
runs/
# Whitelist analysis-ready files committed for dashboard + experiment record:
!results/scores_tier1.parquet
!results/aggregate.parquet
!results/aggregate.extras.json
!results/hypothesis_tests.parquet
!results/stratum_heatmap.parquet
!results/pre_ft_hindi_probe.parquet
!results/predictions.parquet

# Data artifacts (large, deterministically rebuilt from Postgres).
# eval_set.parquet is whitelisted below so the dashboard can render the
# Per-Row Drill page on the deployed app.
data/*.parquet
!data/eval_set.parquet
data/*.jsonl
data/*.sha256
data/hindi_probe.parquet
data/prayas_local.sqlite
data/prayas_local.sqlite-journal
data/prayas_local.sqlite-wal
data/prayas_local.sqlite-shm
data/ft_split/
# (data/upsc_facts.json IS committed — small, deterministic, public-sourced)

# Trained adapters
#   - Raw PEFT adapter files (~24 MB each) ARE committed — irreplaceable, ~22 h FT each.
#   - Merged HF dirs (15+8 GB) are NOT committed — large, deterministically reproducible
#     from the raw adapter + base via scripts/merge_adapter.py.
#   - Mid-training checkpoint dirs are NOT committed (large + redundant); the final
#     trainer_state.json is relocated to adapters/<name>/trainer_state_final.json and
#     committed there.
adapters/*-merged/
adapters/*-mlx/
adapters/*/checkpoint-*/

# Catch-all model-weight rules — apply AFTER the explicit allows below so the
# allows win (gitignore: last matching rule wins).
*.npz
*.safetensors
# Re-allow the small raw PEFT adapter weights (~24 MB each).
!adapters/*/adapter_model.safetensors

# Sidecar venv for legacy BLEURT/SummaC scorers — huge, locally rebuildable
.venv-scorers/

# EC2 PEM keys (also matched by *.pem above, but explicit for the AWS/ dir)
AWS/

# Local research-planning sheet (may contain financial/quota info)
ResourceSheet.xlsx

# Model cache (huge HF downloads)
models/cache/
.cache/

